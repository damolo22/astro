---
// 🧩 FeatureCard — demonstrates Astro PROPS
// Props are like function parameters: you pass data in, the component uses it.
interface Props {
  icon:        string;
  title:       string;
  description: string;
  concept:     string;
  color:       'purple' | 'blue' | 'green' | 'pink' | 'orange';
}

const { icon, title, description, concept, color } = Astro.props;
---

<article class={`card card--${color}`}>
  <div class="card-glow" aria-hidden="true"></div>
  <span class="card-icon">{icon}</span>
  <div class="card-body">
    <span class={`tag tag-${color}`}>{concept}</span>
    <h3>{title}</h3>
    <p>{description}</p>
    <!-- 🎰 <slot /> lets callers inject extra HTML content -->
    <slot />
  </div>
</article>

<style>
  .card {
    position: relative;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform .25s, box-shadow .25s, border-color .25s;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(255,255,255,.16);
  }

  .card-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    border-radius: inherit;
    transition: opacity .3s;
    pointer-events: none;
  }
  .card:hover .card-glow { opacity: 1; }

  .card--purple:hover { box-shadow: 0 20px 60px rgba(124,58,237,.25); }
  .card--purple .card-glow { background: radial-gradient(ellipse at top left, rgba(124,58,237,.2), transparent 70%); }

  .card--blue:hover { box-shadow: 0 20px 60px rgba(56,189,248,.2); }
  .card--blue .card-glow { background: radial-gradient(ellipse at top left, rgba(56,189,248,.18), transparent 70%); }

  .card--green:hover { box-shadow: 0 20px 60px rgba(52,211,153,.2); }
  .card--green .card-glow { background: radial-gradient(ellipse at top left, rgba(52,211,153,.18), transparent 70%); }

  .card--pink:hover { box-shadow: 0 20px 60px rgba(244,114,182,.2); }
  .card--pink .card-glow { background: radial-gradient(ellipse at top left, rgba(244,114,182,.18), transparent 70%); }

  .card--orange:hover { box-shadow: 0 20px 60px rgba(251,146,60,.2); }
  .card--orange .card-glow { background: radial-gradient(ellipse at top left, rgba(251,146,60,.18), transparent 70%); }

  .card-icon {
    font-size: 2.4rem;
    line-height: 1;
    filter: drop-shadow(0 0 12px currentColor);
  }

  .card-body { display: flex; flex-direction: column; gap: .6rem; }

  h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -.01em;
  }
  p {
    font-size: .9rem;
    color: var(--muted);
    line-height: 1.65;
  }
</style>
