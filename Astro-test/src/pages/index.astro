---
// 🚀 index.astro — The main page
// Everything between the triple-dashes (---) runs on the SERVER at build time.
// No JS from this block ever reaches the browser!

import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Counter from '../components/Counter.astro';

// ✅ Regular JS/TS you can use at build time
const year = new Date().getFullYear();

const techStack = ['Astro', 'HTML', 'CSS', 'TypeScript', 'Vite'];

// ✅ Data-driven rendering: loop over an array to generate cards
const features = [
  {
    icon: '🏗️',
    title: 'Component-Based Architecture',
    description:
      'Astro uses .astro files — each is a component that combines a frontmatter script, HTML template, and scoped CSS in one file.',
    concept: 'Components',
    color: 'purple',
    code: `import Nav from '../components/Nav.astro';`,
  },
  {
    icon: '📦',
    title: 'Props — Passing Data In',
    description:
      'Components accept typed props via Astro.props, just like React. Parent passes values, child renders them.',
    concept: 'Props',
    color: 'blue',
    code: `const { title, color } = Astro.props;`,
  },
  {
    icon: '🎰',
    title: 'Slots — Composing HTML',
    description:
      'Use <slot /> inside a component to create "holes" where parent content gets injected. Named slots let you have multiple.',
    concept: 'Slots',
    color: 'green',
    code: `<slot name="header" />`,
  },
  {
    icon: '🗂️',
    title: 'File-Based Routing',
    description:
      'Every .astro file in src/pages/ becomes a URL automatically. No router config needed!',
    concept: 'Routing',
    color: 'pink',
    code: `src/pages/about.astro → /about`,
  },
  {
    icon: '🔁',
    title: 'Loops & Expressions',
    description:
      'Render lists with .map() directly in your template. Astro evaluates JS expressions inside curly braces {}.',
    concept: 'Templating',
    color: 'orange',
    code: `{items.map(i => <li>{i}</li>)}`,
  },
  {
    icon: '⚡',
    title: 'Zero-JS by Default',
    description:
      'Astro ships ZERO JavaScript to the browser unless you need it. Static HTML = blazing fast pages.',
    concept: 'Performance',
    color: 'purple',
    code: `// No bundle unless you use <script>`,
  },
] as const;
---

<Layout title="Astro Showcase 🚀">
  <!-- ── HERO ── -->
  <header class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="orb orb1"></div>
      <div class="orb orb2"></div>
    </div>
    <div class="hero-content">
      <span class="badge">
        <span class="badge-dot"></span>
        Running on Astro {Astro.generator.split('@')[1] ?? ''}
      </span>
      <h1>
        Welcome to <span class="gradient-text">Astro</span> 🚀
      </h1>
      <p class="hero-sub">
        A hands-on showcase of what Astro can do — components, props, slots,
        loops, routing and client-side islands, all in one page.
      </p>

      <!-- 🔁 LOOPS: .map() renders a tag for each item -->
      <div class="tech-row">
        {techStack.map((tech) => (
          <span class="tech-chip">{tech}</span>
        ))}
      </div>
    </div>
  </header>

  <main>
    <!-- ── CONCEPT CALLOUT ── -->
    <section class="callout-section">
      <div class="callout">
        <span class="callout-icon">💡</span>
        <div>
          <strong>How Astro works</strong>
          <p>
            Code in <code>---frontmatter---</code> runs at <em>build time</em> on the server.
            Your HTML template renders to pure HTML. Add <code>&lt;script&gt;</code> tags only
            when you need browser interactivity — the "Islands" model.
          </p>
        </div>
      </div>
    </section>

    <!-- ── FEATURE CARDS GRID ── -->
    <section class="section">
      <div class="section-title">
        <span class="tag tag-purple">Core Concepts</span>
        <h2>What Astro Can Do</h2>
        <p>Each card below is the <code>&lt;FeatureCard /&gt;</code> component called with different props.</p>
      </div>

      <div class="grid">
        {features.map((f) => (
          <FeatureCard
            icon={f.icon}
            title={f.title}
            description={f.description}
            concept={f.concept}
            color={f.color}
          >
            {/* Slot content — injected into the card's <slot /> */}
            <pre class="code-snippet"><code>{f.code}</code></pre>
          </FeatureCard>
        ))}
      </div>
    </section>

    <!-- ── INTERACTIVE ISLAND ── -->
    <section class="section">
      <div class="section-title">
        <span class="tag tag-green">Islands Architecture</span>
        <h2>Client-Side Interactivity</h2>
        <p>This <code>&lt;Counter /&gt;</code> component uses a <code>&lt;script&gt;</code> tag — an "island" of JS in the static page.</p>
      </div>
      <div class="island-wrapper">
        <Counter label="Astro Island Counter" initialCount={0} />
      </div>
    </section>

    <!-- ── CONDITIONAL RENDERING ── -->
    <section class="section">
      <div class="section-title">
        <span class="tag tag-blue">Templating</span>
        <h2>Conditional Rendering</h2>
        <p>Use <code>&&</code> or ternary expressions to render content conditionally.</p>
      </div>
      <div class="conditions-grid">
        {[true, false].map((val) => (
          <div class={`condition-block ${val ? 'condition-yes' : 'condition-no'}`}>
            <span class="condition-icon">{val ? '✅' : '❌'}</span>
            <span class="condition-label">{val ? 'Truthy → renders' : 'Falsy → skipped'}</span>
            <code class="condition-code">{`{${val} && <span>...</span>}`}</code>
          </div>
        ))}
      </div>
    </section>

    <!-- ── LAYOUT DEMO ── -->
    <section class="section">
      <div class="callout callout-purple">
        <span class="callout-icon">🎰</span>
        <div>
          <strong>You're looking at a Layout + Slot right now</strong>
          <p>
            This entire page is wrapped in <code>&lt;Layout&gt;</code>. That component has a
            <code>&lt;slot /&gt;</code> which injects all this content into its HTML shell.
            Change the layout once → every page updates.
          </p>
        </div>
      </div>
    </section>
  </main>

  <!-- ── FOOTER ── -->
  <footer class="footer">
    <p>Built with <span class="gradient-text">Astro</span> · {year} · Zero JS shipped for this text 🚀</p>
    <a href="https://docs.astro.build" target="_blank" rel="noopener" class="footer-link">
      Read the Docs →
    </a>
  </footer>
</Layout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5rem 1.5rem 4rem;
  }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: .45;
  }
  .orb1 {
    width: 500px; height: 500px;
    background: var(--accent);
    top: -200px; left: -100px;
  }
  .orb2 {
    width: 400px; height: 400px;
    background: var(--accent3);
    bottom: -150px; right: -80px;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    max-width: 680px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .78rem;
    font-weight: 600;
    color: var(--accent2);
    background: rgba(124,58,237,.15);
    border: 1px solid rgba(124,58,237,.35);
    border-radius: 99px;
    padding: .3rem .85rem;
  }
  .badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .5; transform: scale(.7); }
  }
  h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -.03em;
    color: #fff;
    line-height: 1.1;
  }
  .gradient-text {
    background: linear-gradient(135deg, var(--accent2) 30%, var(--accent3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 520px;
    line-height: 1.7;
  }
  .tech-row {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    justify-content: center;
    margin-top: .5rem;
  }
  .tech-chip {
    font-size: .78rem;
    font-weight: 600;
    padding: .3rem .8rem;
    border-radius: 99px;
    background: rgba(255,255,255,.07);
    border: 1px solid var(--border);
    color: var(--text);
    letter-spacing: .04em;
    transition: background .2s, border-color .2s;
  }
  .tech-chip:hover {
    background: rgba(124,58,237,.25);
    border-color: var(--accent2);
  }

  /* ── MAIN ── */
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* ── SECTIONS ── */
  .section { display: flex; flex-direction: column; gap: 2rem; }
  .section-title {
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }
  .section-title h2 {
    font-size: 1.9rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -.02em;
  }
  .section-title p { color: var(--muted); font-size: .95rem; }

  /* ── CALLOUT ── */
  .callout-section {
    margin-top: -1rem;
  }
  .callout {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent2);
    border-radius: var(--radius);
    padding: 1.4rem 1.6rem;
  }
  .callout-purple { border-left-color: var(--accent); }
  .callout-icon { font-size: 1.6rem; flex-shrink: 0; }
  .callout strong { display: block; color: #fff; margin-bottom: .4rem; font-size: .95rem; }
  .callout p { font-size: .88rem; color: var(--muted); line-height: 1.65; }

  /* ── GRID ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.2rem;
  }

  /* ── CODE SNIPPET inside card slot ── */
  .code-snippet {
    margin-top: .4rem;
    background: rgba(0,0,0,.35);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: .6rem .9rem;
    font-size: .78rem;
    overflow-x: auto;
  }
  .code-snippet code {
    background: none;
    color: var(--accent2);
    padding: 0;
    font-family: var(--mono);
  }

  /* ── ISLAND ── */
  .island-wrapper {
    max-width: 480px;
  }

  /* ── CONDITIONS ── */
  .conditions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .condition-block {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    padding: 1.4rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .condition-yes { border-color: rgba(52,211,153,.3); }
  .condition-no  { border-color: rgba(244,114,182,.3); }
  .condition-icon { font-size: 1.8rem; }
  .condition-label { font-weight: 600; font-size: .9rem; color: #fff; }
  .condition-code {
    font-size: .78rem;
    font-family: var(--mono);
    color: var(--muted);
    background: rgba(0,0,0,.3);
    padding: .4rem .7rem;
    border-radius: 6px;
    border: none;
  }

  /* ── FOOTER ── */
  .footer {
    text-align: center;
    padding: 2.5rem 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .8rem;
    color: var(--muted);
    font-size: .88rem;
  }
  .footer-link {
    color: var(--accent2);
    text-decoration: none;
    font-weight: 600;
    transition: color .2s;
  }
  .footer-link:hover { color: var(--accent3); }
</style>
