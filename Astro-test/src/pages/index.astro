---
export const prerender = true;

import SocialLayout from '../layouts/SocialLayout.astro';
import SmoothieCard from '../components/SmoothieCard.astro';

// This runs ONLY on the server during build (or SSR). It will never ship to the client!
// Fetching the simulated data from our local Laravel API.
const response = await fetch('http://127.0.0.1:8000/api/smoothies');
const smoothies = await response.json();
---

<SocialLayout title="SmoothieSocial Feed">
  <!-- Iterate through all the fetched smoothies from Laravel and render pure HTML cards -->
  {smoothies.map((smoothie) => (
    <SmoothieCard smoothie={smoothie} />
  ))}
</SocialLayout>
